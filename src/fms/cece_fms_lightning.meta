[fms-table-properties]
  name = cece_fms_lightning
  type = scheme
  dependencies = cece_fms_state.F90

[fms-arg-table]
  name = cece_lightning_init
  type = scheme
[horizontal_loop_extent]
  standard_name = horizontal_loop_extent
  long_name = horizontal loop extent
  units = count
  dimensions = ()
  type = integer
  intent = in
[vertical_layer_dimension]
  standard_name = vertical_layer_dimension
  long_name = number of vertical layers
  units = count
  dimensions = ()
  type = integer
  intent = in
[cece_configuration_file_path]
  standard_name = cece_configuration_file_path
  long_name = path to CECE YAML configuration file
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = in
[errmsg]
  standard_name = fms_error_message
  long_name = error message for error handling in FMS
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = out
[errflg]
  standard_name = fms_error_code
  long_name = error code for error handling in FMS
  units = 1
  dimensions = ()
  type = integer
  intent = out

[fms-arg-table]
  name = cece_lightning_run
  type = scheme
[horizontal_loop_extent]
  standard_name = horizontal_loop_extent
  long_name = horizontal loop extent
  units = count
  dimensions = ()
  type = integer
  intent = in
[vertical_layer_dimension]
  standard_name = vertical_layer_dimension
  long_name = number of vertical layers
  units = count
  dimensions = ()
  type = integer
  intent = in
[convective_cloud_top_pressure]
  standard_name = convective_cloud_top_pressure
  long_name = convective cloud top pressure
  units = Pa
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[convective_cloud_bottom_pressure]
  standard_name = convective_cloud_bottom_pressure
  long_name = convective cloud bottom pressure
  units = Pa
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[lightning_nox_emission_flux]
  standard_name = lightning_nox_emission_flux
  long_name = lightning NOx emission flux
  units = kg m-2 s-1
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = out
[errmsg]
  standard_name = fms_error_message
  long_name = error message for error handling in FMS
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = out
[errflg]
  standard_name = fms_error_code
  long_name = error code for error handling in FMS
  units = 1
  dimensions = ()
  type = integer
  intent = out

[fms-arg-table]
  name = cece_lightning_finalize
  type = scheme
[errmsg]
  standard_name = fms_error_message
  long_name = error message for error handling in FMS
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = out
[errflg]
  standard_name = fms_error_code
  long_name = error code for error handling in FMS
  units = 1
  dimensions = ()
  type = integer
  intent = out

[fms-arg-table]
